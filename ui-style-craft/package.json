{
  "name": "ui-style-craft",
  "version": "1.0.0",
  "description": "CodeBuddy UI 视觉质量增强技能：design token 生成 / WCAG 对比度校验 / 反模式体检（纯 Node.js，零依赖）。",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "tokens": "node scripts/generate-tokens.mjs",
    "tokens:wx": "node scripts/generate-tokens.mjs --platform wechat --out wxss,json",
    "contrast": "node scripts/validate-contrast.mjs",
    "audit": "node scripts/audit-styles.mjs",
    "pack": "node scripts/pack.mjs"
  }
}
